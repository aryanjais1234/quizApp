# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT (must match the Spring Boot secret in user-service) ─────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── Embedding model (Sentence-Transformers) ─────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Downstream microservice URLs ─────────────────────────────────────────────
# Local development (services running outside Docker)
MATERIAL_SERVICE_URL=http://localhost:8082
QUESTION_SERVICE_URL=http://localhost:8086
QUIZ_SERVICE_URL=http://localhost:8081

# Docker Compose (uncomment and use these instead):
# MATERIAL_SERVICE_URL=http://material-service:8082
# QUESTION_SERVICE_URL=http://question-service:8086
# QUIZ_SERVICE_URL=http://quiz-service:8081
